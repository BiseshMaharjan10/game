generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleType {
  news
  opinion
  investigation
  alert
}

enum EventStatus {
  available
  accepted
  completed
  failed
}

model Player {
  id             String         @id @default(cuid())
  firebaseUid    String?        @unique
  passwordHash   String?
  companyName    String?
  email          String         @unique
  displayName    String?
  profilePicture String?
  coins          Int            @default(1000)
  trustScore     Int            @default(0)
  gems           Int            @default(100)
  companyValue   Int            @default(1000)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  company        Company?
  leaderboard    Leaderboard?
  state          PlayerState?
  characters    PlayerCharacter[]
  desks         Desk[]
  eventStates    PlayerEvent[]
  eventHistory   EventHistory[]
}

model Company {
  id                 String        @id @default(cuid())
  ownerId            String        @unique
  name               String
  level              Int           @default(1)
  reputation         Int           @default(50)
  unlockedCharacters String[]      @default([])
  deskAssignments    Json          @default("{}")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  owner              Player        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  articles           Article[]
  events             PlayerEvent[]
}

model CharacterTemplate {
  id            String @id
  displayName   String
  skill         String @default("")
  description   String @default("")
  influence     Int    @default(0)
  timeliness    Int    @default(0)
  accuracy      Int    @default(0)
  category      String @default("junior")
  recruitCoins  Int    @default(0)
  recruitGems   Int    @default(0)
  recurringCost Int    @default(0)
}

model Desk {
  id                  String   @id @default(cuid())
  playerId            String
  deskIndex           Int
  assignedCharacterId String?
  unlocked            Boolean  @default(false)
  cost                Int      @default(500)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  player              Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, deskIndex])
  @@index([playerId])
}

model PlayerCharacter {
  id          String   @id @default(cuid())
  playerId    String
  characterId String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, characterId])
  @@index([playerId])
}

model Article {
  id           String      @id @default(cuid())
  companyId    String
  title        String
  type         ArticleType
  quality      Int
  verifiedInfo Boolean     @default(false)
  isFakeNews   Boolean     @default(false)
  publishedAt  DateTime    @default(now())
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Event {
  id           String         @id @default(cuid())
  title        String
  description  String
  requiredTags String[]       @default([])
  conditions   Json
  choices      Json
  repeatable   Boolean        @default(false)
  difficulty   Int
  reward       Int
  risk         Int
  status       EventStatus    @default(available)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  playerStates PlayerEvent[]
  history      EventHistory[]
}

model StoryTemplate {
  id                  String          @id @default(cuid())
  titleTemplate       String
  descriptionTemplate String
  category            String
  difficulty          Int
  tags                String[]        @default([])
  variables           Json
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  instances           StoryInstance[]
}

model StoryInstance {
  id                   String         @id @default(cuid())
  templateId           String
  generatedTitle       String
  generatedDescription String
  tags                 String[]       @default([])
  variables            Json
  status               String         @default("active")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  template             StoryTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  history              EventHistory[]

  @@index([templateId])
}

model PlayerState {
  id                    String   @id @default(cuid())
  playerId              String   @unique
  money                 Int      @default(1000)
  reputation            Int      @default(50)
  evidence              Int      @default(0)
  investigationProgress Int      @default(0)
  journalists           String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  player                Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model CountryState {
  id            String   @id @default(cuid())
  key           String   @unique @default("global")
  economy       Int      @default(50)
  corruption    Int      @default(50)
  stability     Int      @default(50)
  publicTrust   Int      @default(50)
  currentEvents String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EventHistory {
  id              String        @id @default(cuid())
  playerId        String
  storyInstanceId String
  eventId         String
  selectedChoice  Json
  timestamp       DateTime      @default(now())
  player          Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  storyInstance   StoryInstance @relation(fields: [storyInstanceId], references: [id], onDelete: Cascade)
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([storyInstanceId])
  @@index([eventId])
}

model NewsArticle {
  id          String    @id @default(cuid())
  roomId      Int
  playerId    String
  scenarioId  String
  headline    String    @default("")
  body        String?
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@unique([playerId, scenarioId])
  @@index([roomId])
  @@index([playerId])
}

model InvestigationSnapshot {
  id                   String   @id @default(cuid())
  articleId            String   @unique
  playerId             String
  scenarioId           String
  headline             String   @default("")
  anonymousTip         String   @default("")
  backgroundNews       Json     @default("[]")
  discoveredEvidence   Json     @default("[]")
  witnessStatements    Json     @default("[]")
  generatedArticleBody String?
  createdAt            DateTime @default(now())

  @@index([playerId])
  @@index([scenarioId])
}

model Judgement {
  id             String   @id @default(cuid())
  articleId      String   @unique
  scenarioId     String
  playerId       String
  roomId         Int
  geminiAnalysis Json     @default("{}")
  backendScore   Int      @default(0)
  finalVerdict   String   @default("")
  judgedAt       DateTime @default(now())

  @@index([playerId])
  @@index([scenarioId])
  @@index([roomId])
}

model Leaderboard {
  id        String   @id @default(cuid())
  playerId  String   @unique
  rank      Int      @default(0)
  score     Int      @default(0)
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerEvent {
  id        String      @id @default(cuid())
  playerId  String
  companyId String
  eventId   String
  status    EventStatus @default(accepted)
  progress  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  player    Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([companyId])
  @@index([eventId])
}
