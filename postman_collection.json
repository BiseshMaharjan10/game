{
  "info": {
    "name": "GAM Backend API",
    "description": "Import this collection into Postman to test the current backend routes. Update the `baseUrl` variable to match your local server.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Public endpoint to confirm the server is running."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"password\": \"secret123\",\n  \"company_name\": \"Daily Byte\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a player account. `company_name` is optional, but adding it creates a company immediately."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in with email and password. Save `access_token` into the collection variable `token` and `refresh_token` into `refreshToken`."
          }
        },
        {
          "name": "Refresh Tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Exchanges a refresh token for a new access token and refresh token. Accepts either `refresh_token` or `refreshToken`."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Returns a logout confirmation message. No server-side session invalidation is performed in the current code."
          }
        }
      ]
    },
    {
      "name": "Company",
      "item": [
        {
          "name": "Get Company",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/company",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "company"
              ]
            },
            "description": "Fetches the current player company and journalist roster. Requires `Authorization: Bearer {{token}}`."
          }
        },
        {
          "name": "Create Company",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Daily Byte\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/company/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "company",
                "create"
              ]
            },
            "description": "Creates a company for the logged-in player. `name` is required."
          }
        },
        {
          "name": "Upgrade Company",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/company/upgrade",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "company",
                "upgrade"
              ]
            },
            "description": "Buys the next company upgrade. No body is required."
          }
        }
      ]
    },
    {
      "name": "Journalists",
      "item": [
        {
          "name": "List Journalists",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/journalists",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journalists"
              ]
            },
            "description": "Returns the available journalist roster for the player company."
          }
        },
        {
          "name": "Hire Journalist",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"character\": \"Bob\",\n  \"skill\": 1,\n  \"salary\": 600,\n  \"payment\": \"coin\",\n  \"desk_index\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/journalists/hire",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journalists",
                "hire"
              ]
            },
            "description": "Hires a journalist. The route requires either `character` or `name`. Optional fields: `skill`, `salary`, `payment` or `payment_method`, and `desk_index`."
          }
        },
        {
          "name": "Fire Journalist",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"journalistId\": \"some-journalist-id\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/journalists/fire",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journalists",
                "fire"
              ]
            },
            "description": "Fires a journalist by ID. `journalistId` is required."
          }
        }
      ]
    },
    {
      "name": "Articles",
      "item": [
        {
          "name": "Article History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/articles/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "articles",
                "history"
              ]
            },
            "description": "Returns the published article history for the current company."
          }
        },
        {
          "name": "Publish Article",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"strategy\": \"fast\",\n  \"title\": \"Breaking News\",\n  \"type\": \"news\",\n  \"quality\": 1,\n  \"verifiedInfo\": false,\n  \"isFakeNews\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/articles/publish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "articles",
                "publish"
              ]
            },
            "description": "Publishes an article. `strategy` is required by the route and can be `fast`, `partial`, or `full`. Other fields are optional but useful for testing."
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Lists available events and the player event state."
          }
        },
        {
          "name": "Accept Event",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"some-event-id\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/accept",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "accept"
              ]
            },
            "description": "Accepts an event for the current company. `eventId` is required."
          }
        },
        {
          "name": "Complete Event",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"some-event-id\",\n  \"success\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "complete"
              ]
            },
            "description": "Completes an accepted event. `eventId` is required. Set `success` to `false` to simulate failure."
          }
        }
      ]
    },
    {
      "name": "Economy",
      "item": [
        {
          "name": "Get Economy",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/economy",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "economy"
              ]
            },
            "description": "Returns economy metrics for the current player."
          }
        },
        {
          "name": "Get Economy Stats",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/economy/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "economy",
                "stats"
              ]
            },
            "description": "Returns economy-related player stats plus journalist count."
          }
        },
        {
          "name": "Get Full Stats",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stats"
              ]
            },
            "description": "Returns the full game stats snapshot for the current player."
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leaderboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leaderboard"
              ]
            },
            "description": "Returns the current leaderboard standings."
          }
        }
      ]
    }
  ]
}
